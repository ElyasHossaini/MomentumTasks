# Optional: contact API origin when it is not the same host as the site (no trailing slash).
# Leave unset in local dev — Vite proxies /api to the Node server on port 8787.
# VITE_CONTACT_API_URL=https://api.yourdomain.com

# Vercel: set EMAIL_USER, EMAIL_PASS, MAIL_TO in Project → Settings → Environment Variables (not in this file).
